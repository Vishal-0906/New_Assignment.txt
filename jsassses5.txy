Q13. Build a reusable function called createPlaylistButton(songName, themeColor) that returns a button element styled with the given color and displaying the song name. Use this function to create and display three buttons for your favorite Spotify tracks.

`javascript
function createPlaylistButton(songName, themeColor) {
  const button = document.createElement("button");
  button.textContent = songName;
  button.style.backgroundColor = themeColor;
  button.style.color = "white";
  button.style.margin = "5px";
  document.body.appendChild(button);
  return button;
}

// Example usage
createPlaylistButton("Shape of You", "purple");
createPlaylistButton("Blinding Lights", "blue");
createPlaylistButton("Levitating", "green");
