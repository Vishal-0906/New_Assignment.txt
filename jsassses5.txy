Q10. Build a mini Zomato-style feature: write a function showMenuItem(name, price) that returns a styled HTML div with the food item's name and price, then call it for three different items and display them on the page.

`javascript
function showMenuItem(name, price) {
  const itemDiv = document.createElement("div");
  itemDiv.style.border = "1px solid #ccc";
  itemDiv.style.padding = "10px";
  itemDiv.style.margin = "5px";
  itemDiv.textContent = ${name} - ₹${price};
  document.body.appendChild(itemDiv);
  return itemDiv;
}

// Example usage
showMenuItem("Pizza", 299);
showMenuItem("Burger", 199);
showMenuItem("Pasta", 249);
`

---

